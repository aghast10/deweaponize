{
  "manifest_version": 2,
  "name": "Pharmakon",
  "version": "0.2.0",
  "description": "Rewrites text on web pages in your chosen tone using Claude.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "tabs",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.svg"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["sites.js", "content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  }
}
